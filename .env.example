# ===========================================
# LINE Harness - Environment Variables
# ===========================================
# Docker (self-hosted): `cp .env.example .env`; docker-compose feeds this file
#   to the backend container as-is (see docs/DOCKER.md).
# Cloudflare Workers (legacy): set secrets via `wrangler secret put <NAME>`.
# For Web: copy to apps/web/.env.local

# --- Backend ---
# On Docker/VPS, set WORKER_URL to the public HTTPS URL of your backend
# (reverse-proxy domain), e.g. https://line.example.com
API_KEY=your-api-key
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_LOGIN_CHANNEL_ID=your-line-login-channel-id
LINE_LOGIN_CHANNEL_SECRET=your-line-login-channel-secret
WORKER_URL=https://your-worker.workers.dev
LIFF_URL=https://liff.line.me/your-liff-id
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# --- Object storage (S3-compatible; MinIO by default) ---
# See docker-compose.yml (local MinIO) and docs/storage-migration.md.
# Non-secret vars (S3_ENDPOINT/S3_BUCKET/S3_REGION/S3_FORCE_PATH_STYLE) live in
# wrangler.toml [vars]; the keys below are secrets → `wrangler secret put <NAME>`.
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=line-harness-images
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=auto
# 'true' for MinIO/self-hosted (path-style); 'false' for AWS S3 vhost addressing.
S3_FORCE_PATH_STYLE=true

# --- Admin auth (cookie session) ---
# The admin dashboard authenticates with an HttpOnly session cookie (no API key
# in localStorage). When the admin (Pages, *.pages.dev) and API (Worker,
# *.workers.dev) are on different sites, the cookie must be SameSite=None;
# Secure and the admin origin must be allow-listed for credentialed CORS.
# `create-line-harness` sets these automatically; set them manually for custom
# deployments.
#   ADMIN_ORIGIN: comma-separated admin origin allowlist (no trailing slash)
ADMIN_ORIGIN=https://your-admin.pages.dev
#   true → issue SameSite=None; Secure cookies (required for the cross-site
#   Pages↔Workers topology). Omit/false when admin and API share a registrable
#   domain (e.g. admin.example.com + api.example.com), where SameSite=Lax works.
ADMIN_ALLOW_CROSS_SITE=true
#   Optional override: Strict | Lax | None (normally derived automatically)
# ADMIN_COOKIE_SAMESITE=None

# Optional: Cross-account linking
X_HARNESS_URL=https://your-other-harness.workers.dev

# Optional: OpenAI-compatible chat auto-reply fallback defaults.
# You can now also set/override these from Admin > LINEアカウント > グローバル設定.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# --- Web App (Next.js Admin Dashboard) ---
# Copy to apps/web/.env.local
NEXT_PUBLIC_API_URL=https://your-worker.workers.dev

# --- MCP Server ---
# Set in your MCP client config
LINE_HARNESS_API_URL=https://your-worker.workers.dev
LINE_HARNESS_API_KEY=your-api-key
LINE_HARNESS_ACCOUNT_ID=optional-account-id

# --- PostgreSQL (docker-compose, replaces Cloudflare D1) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=linecrm
POSTGRES_PORT=5432
# Connection string used by the backend and by packages/db/scripts/pg-migrate.mjs
# when run from the HOST. Inside docker-compose the backend container gets a
# DATABASE_URL pointing at the postgres service instead (see docker-compose.yml).
DATABASE_URL=postgres://postgres:change-me@localhost:5432/linecrm

# --- Docker backend (docker-compose) ---
# Host port the backend is published on (container listens on 8787).
BACKEND_PORT=8787
